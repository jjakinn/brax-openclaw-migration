  "prerequisites": {
    "tools": [
      "Visual Studio Code",
      "Git",
      ".NET",
      "Node.js",
      "npm"
    ],
    "extensions": [
      "Power Platform Tools (VS Code extension)"
    ],
    "cli": "Power Apps CLI (pac)"
  },
  "setup_workflow": [
    {
      "step": 1,
      "action": "Create Vite project",
      "command": "npm create vite@latest",
      "details": "Select React + TypeScript template"
    },
    {
      "step": 2,
      "action": "Install dependencies",
      "commands": ["npm install", "npm install --save-dev @types/node"]
    },
    {
      "step": 3,
      "action": "Update Vite config",
      "file": "vite.config.ts",
      "purpose": "Configure for Code Apps"
    },
    {
      "step": 4,
      "action": "Authenticate with Power Platform",
      "command": "pac auth create",
      "details": "Login with Power Platform account"
    },
    {
      "step": 5,
      "action": "Select environment",
      "command": "pac env select",
      "details": "Provide environment URL from Power Platform admin center"
    },
    {
      "step": 6,
      "action": "Initialize Code App",
      "command": "pac code init",
      "creates": "power.config.json file in project"
    },
    {
      "step": 7,
      "action": "Install Power SDK",
      "source": "GitHub release",
      "added_to": "package.json"
    },
    {
      "step": 8,
      "action": "Add Power Provider",
      "files": ["PowerProvider.tsx", "Update main.tsx"],
      "purpose": "Initialize Power Platform integration"
    },
    {
      "step": 9,
      "action": "Run locally with Power SDK",
      "command": "npm run dev",
      "starts": ["Vite dev server", "Power SDK server"],
      "test_url": "http://localhost:5173 (with Power SDK proxy)"
    },
    {
      "step": 10,
      "action": "Build for production",
      "command": "npm run build"
    },
    {
      "step": 11,
      "action": "Deploy to Power Platform",
      "command": "pac code push",
      "result": "App available in Power Platform environment"
    }
  ],

    "dDurationMs": 3801,
    "segs": [ {
      "utf8": "a child born under the number 7 was \nimmediately placed in the temple to\n "
    } ]
  }, {
    "tStartMs": 20457400,
    "dDurationMs": 5639,
    "segs": [ {
      "utf8": "become a priest or priestess. Today 7’s \nare found in the higher echelons of\n "
    } ]
  }, {

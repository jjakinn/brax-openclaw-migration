    "dDurationMs": 5039,
    "segs": [ {
      "utf8": "not enter into the business field, \nbecause you seldom carry out those ideas.\n "
    } ]
  }, {
    "tStartMs": 20553719,
    "dDurationMs": 3721,
    "segs": [ {
      "utf8": "Unselfishness, compassion and \ndedication are qualities you should\n "
    } ]
  }, {

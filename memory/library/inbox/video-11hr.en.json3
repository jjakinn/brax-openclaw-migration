  }, {
    "tStartMs": 6096040,
    "dDurationMs": 5760,
    "segs": [ {
      "utf8": "all that was, is and ever shall be;\nspirit, the I Am; love because it  "
    } ]
  }, {
    "tStartMs": 6101800,
    "dDurationMs": 5320,
    "segs": [ {
      "utf8": "encompasses, enfolds and contains;\nbalance, because however you turn it,  "

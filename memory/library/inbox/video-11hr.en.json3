    "dDurationMs": 5041,
    "segs": [ {
      "utf8": "away to make room for new and better ones.\nBe prepared to meet fresh ideas,  "
    } ]
  }, {
    "tStartMs": 23335920,
    "dDurationMs": 4959,
    "segs": [ {
      "utf8": "new people and stimulating conditions.\nA change of plans, a new location and  "
    } ]
  }, {
    "tStartMs": 23340879,
    "dDurationMs": 3160,
    "segs": [ {
      "utf8": "different people open the birth\nchannel for new opportunities.  "
    } ]
  }, {
    "tStartMs": 23344879,
    "dDurationMs": 3561,
    "segs": [ {
      "utf8": "This is a reconstruction period, which can\nbring great happiness if you make the  "
    } ]
  }, {
    "tStartMs": 23348439,
    "dDurationMs": 5279,
    "segs": [ {
      "utf8": "right decisions. The events that occur\nmay not necessitate physical action on your  "
    } ]
  }, {
    "tStartMs": 23353719,
    "dDurationMs": 5080,
    "segs": [ {
      "utf8": "part, but they will require you\nto make the proper assessments.\n "
    } ]
  }, {
    "tStartMs": 23358799,
    "dDurationMs": 5080,
    "segs": [ {
      "utf8": "Change is the basis of earthly \nmanifestation. Upon the wave of change\n "
    } ]
  }, {
    "tStartMs": 23363879,
    "dDurationMs": 4721,
    "segs": [ {
      "utf8": "you can sail to a new fertile land where \na fresh lifestyle is possible. Release\n "
    } ]
  }, {

  }, {
    "tStartMs": 23392320,
    "dDurationMs": 6238,
    "segs": [ {
      "utf8": "or mouth of the uterus. This symbol suggests\nreproduction and birth, not necessarily into  "
    } ]
  }, {
    "tStartMs": 23398559,
    "dDurationMs": 3602,
    "segs": [ {
      "utf8": "this world but rather rebirth of\nthe consciousness into higher  "
    } ]
  }, {
    "tStartMs": 23402160,
    "dDurationMs": 7680,
    "segs": [ {
      "utf8": "planes. In the time of Christ, the fish symbol\nrepresented those who lived in a Christlike way.\n "
    } ]
  }, {
    "tStartMs": 23409840,
    "dDurationMs": 5920,
    "segs": [ {
      "utf8": "The number 13 is sacred as is every \nmultiple of 13. It connotes an initiate\n "
    } ]
  }, {
    "tStartMs": 23415760,
    "dDurationMs": 4561,
    "segs": [ {
      "utf8": "or one who is reborn through the mental \npowers of transmutation. There are\n "
    } ]
  }, {
    "tStartMs": 23420320,
    "dDurationMs": 5279,
    "segs": [ {
      "utf8": "twelve disciples, Jesus was the thirteenth; \nthere are twelve zodiacal signs\n "
    } ]
  }, {
    "tStartMs": 23425600,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "with the Sun at the center. Number 13 \nis preserved in the measurements of\n "
    } ]
  }, {
    "tStartMs": 23429600,
    "dDurationMs": 4801,
    "segs": [ {
      "utf8": "the Great Pyramid.\nAstrologically, this card is ruled by Scorpio,  "
    } ]
  }, {
    "tStartMs": 23434400,
    "dDurationMs": 2078,
    "segs": [ {
      "utf8": "which governs the\nreproductive organs,  "
    } ]
  }, {
    "tStartMs": 23436479,
    "dDurationMs": 5281,
    "segs": [ {
      "utf8": "birth, death and transmutation.\nThe skeleton is the figure of Death,  "
    } ]
  }, {

    "dDurationMs": 5120,
    "segs": [ {
      "utf8": "Triangle as a blueprint of his life. We \nwill present only basic biographical\n "
    } ]
  }, {
    "tStartMs": 12872120,
    "dDurationMs": 4640,
    "segs": [ {
      "utf8": "information because Edgar Cayce is \nwell-known, and written material on\n "
    } ]
  }, {
    "tStartMs": 12876760,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "his life is plentiful.\nEdgar Cayce was born near Hopkinsville,  "
    } ]
  }, {
    "tStartMs": 12881760,
    "dDurationMs": 6000,
    "segs": [ {
      "utf8": "Kentucky, on March 18, 1877.\nAlthough poor and uneducated,  "
    } ]
  }, {
    "tStartMs": 12887760,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "he was to become a beloved figure known\nas the sleeping prophet. A deeply  "
    } ]
  }, {
    "tStartMs": 12892439,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "religious man, he lived a devout\nChristian life and used his remarkable  "
    } ]
  }, {
    "tStartMs": 12896760,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "psychic talents to benefit others.\nPutting himself into a trance, Cayce  "
    } ]
  }, {
    "tStartMs": 12901520,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "would diagnose the illnesses of those\nwho consulted him, and then recommend  "
    } ]
  }, {
    "tStartMs": 12905520,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "treatments and cures. He also\npossessed the ability to read the  "
    } ]
  }, {
    "tStartMs": 12909479,
    "dDurationMs": 5480,
    "segs": [ {
      "utf8": "akashic records. It is said that every sound,\nthought and vibration since the beginning  "
    } ]
  }, {
    "tStartMs": 12914960,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "of time is registered on these\nrecords, including the first sound  "
    } ]
  }, {
    "tStartMs": 12918960,
    "dDurationMs": 5359,
    "segs": [ {
      "utf8": "vibration which called forth manifestation.\nBased on the akashic records of those  "
    } ]
  }, {
    "tStartMs": 12924319,
    "dDurationMs": 3841,

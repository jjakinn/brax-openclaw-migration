    "dDurationMs": 5320,
    "segs": [ {
      "utf8": "nature reigns here, as the old is replaced \nby the new. The king is dead; long\n "
    } ]
  }, {
    "tStartMs": 23383760,
    "dDurationMs": 2879,
    "segs": [ {
      "utf8": "live the king.\nTAROT SYMBOLISM:  "
    } ]
  }, {
    "tStartMs": 23386639,
    "dDurationMs": 5682,
    "segs": [ {
      "utf8": "Key 13. Death. The keywords corresponding to\nthis card are fish, fish’s mouth,  "

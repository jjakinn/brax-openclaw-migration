    "tStartMs": 20535479,
    "dDurationMs": 5041,
    "segs": [ {
      "utf8": "have their own distinct vibrations,\nwhich are transmitted to anything they touch.\n "
    } ]
  }, {
    "tStartMs": 20540520,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "You are methodical, in keeping with \nthe rhythm of the 7 which rules\n "
    } ]
  }, {
    "tStartMs": 20544520,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "periodicity in nature. Although you \nhave good business ideas, you should\n "
    } ]
  }, {

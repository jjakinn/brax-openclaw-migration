    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "digit in the series of\nsingle digits;  "
    } ]
  }, {
    "tStartMs": 6123200,
    "dDurationMs": 4920,
    "segs": [ {
      "utf8": "when multiplied by another number, \nthe result always reduces again to 9.\n "
    } ]
  }, {
    "tStartMs": 6128120,
    "dDurationMs": 9240,
    "segs": [ {
      "utf8": "(2 times 9 is 18 or 9; 3 times 9 is 27 \nor 9; 4 times 9 is 36 or 9; and so on.) \n "
    } ]
  }, {
    "tStartMs": 6137360,
    "dDurationMs": 5000,
    "segs": [ {
      "utf8": "A circle has no beginning and no \nend; it is infinite and endless. \n "
    } ]

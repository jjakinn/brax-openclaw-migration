    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "entire being. Others could set a pattern \nafter your well-ordered program of\n "
    } ]
  }, {
    "tStartMs": 3145320,
    "dDurationMs": 4760,
    "segs": [ {

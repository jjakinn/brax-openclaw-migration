    "dDurationMs": 5120,
    "segs": [ {
      "utf8": "planned, practical way.\n5 AS THE SOUL NUMBER:  "
    } ]
  }, {
    "tStartMs": 3167720,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "You claim the right to freedom and will\nnot allow any limitations of your  "
    } ]
  }, {

    } ]
  }, {
    "tStartMs": 13797760,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "personal year. By the minor process we \nfind Cayce had a 26 or 8 experience at\n "
    } ]
  }, {
    "tStartMs": 13802800,
    "dDurationMs": 4960,
    "segs": [ {
      "utf8": "age 20, the year he fell in love and \nproposed marriage to Gertrude Evans.\n "
    } ]
  }, {
    "tStartMs": 13807760,
    "dDurationMs": 4760,
    "segs": [ {
      "utf8": "Not only does the 8 correspond with \nthe Life Lesson Number (44 reduced),\n "

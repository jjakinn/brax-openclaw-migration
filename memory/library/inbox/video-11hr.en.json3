    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "fulfill duties, either real or imagined. \nYour keen sense of value makes you\n "
    } ]
  }, {
    "tStartMs": 4717240,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "dislike the mediocre. You know that \nwhat is worth having is worth working\n "
    } ]
  }, {
    "tStartMs": 4721080,
    "dDurationMs": 6440,
    "segs": [ {
      "utf8": "and waiting for.\n5 AS THE PATH OF DESTINY: Many changes occur in\n "

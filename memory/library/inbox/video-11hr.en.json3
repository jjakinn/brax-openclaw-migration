    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "philosophy of life. Follow your urge\nto create and expand the activities  "
    } ]
  }, {
    "tStartMs": 3099080,
    "dDurationMs": 5880,
    "segs": [ {
      "utf8": "that interest you. You seek happiness and\nfind it in making others happy. If a person  "

    "dDurationMs": 6000,
    "segs": [ {
      "utf8": "destructive rather than regenerative. \nYou are in a state of spiritual amnesia.\n "
    } ]
  }, {
    "tStartMs": 23264760,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "You above all others have the ability \nto bring about peaceful changes that\n "

  }, {
    "tStartMs": 6063560,
    "dDurationMs": 5200,
    "segs": [ {
      "utf8": "Through the authors’ research, logic, \nwork, meditation and intuition, the\n "
    } ]
  }, {
    "tStartMs": 6068760,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "following concepts have emerged. \nMany ideas presented here have been\n "
    } ]
  }, {
    "tStartMs": 6072600,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "accepted for ages, some are relatively \nrecent, and the remaining are totally\n "

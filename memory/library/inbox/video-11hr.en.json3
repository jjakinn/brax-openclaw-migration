    "segs": [ {
      "utf8": "a triangle with the point down which \nis an ancient symbol for water.\n "
    } ]
  }, {
    "tStartMs": 22956400,
    "dDurationMs": 3719,
    "segs": [ {
      "utf8": "The Hanged Man represents a person \nwho is poised in consciousness and\n "

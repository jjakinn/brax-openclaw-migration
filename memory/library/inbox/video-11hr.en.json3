  }, {
    "tStartMs": 20517279,
    "dDurationMs": 4199,
    "segs": [ {
      "utf8": "that environment, you can experience \nthe periods of quiet contemplation\n "
    } ]
  }, {
    "tStartMs": 20521479,
    "dDurationMs": 6121,
    "segs": [ {
      "utf8": "that are necessary for your mental development.\nThe fastidiousness of your dress is unique;  "
    } ]

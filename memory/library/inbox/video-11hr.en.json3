    "dDurationMs": 5801,
    "segs": [ {
      "utf8": "at once. Sometimes you make people uneasy\nwith your ability to see right through them.\n "
    } ]
  }, {
    "tStartMs": 20485080,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "Thoughts are words of the mind, \nand you become close friends with\n "

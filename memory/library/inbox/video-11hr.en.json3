    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "2 AS THE SOUL NUMBER: You have \na strong desire for peace and\n "
    } ]
  }, {
    "tStartMs": 3031680,
    "dDurationMs": 4680,
    "segs": [ {
      "utf8": "harmony. You are considerate and \ntactful, adaptable and gentle. You\n "
    } ]
  }, {

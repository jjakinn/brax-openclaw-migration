    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "of practical goals in the present life.\nYou are always conscious of your inner  "
    } ]
  }, {
    "tStartMs": 2983200,
    "dDurationMs": 3920,
    "segs": [ {

    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "might therefore find the financial\nworld a fertile spot for your talents.\n "
    } ]
  }, {
    "tStartMs": 4702680,
    "dDurationMs": 5120,
    "segs": [ {
      "utf8": "Your keywords are impatience, honesty, \ndetermination and confidence.\n "
    } ]
  }, {
    "tStartMs": 4707800,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "You demand obedience in the family and \nwill practice self-denial in order to\n "

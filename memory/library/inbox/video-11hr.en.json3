    "tStartMs": 12853399,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "can be implemented to delineate \nan individual’s life. \n "
    } ]
  }, {
    "tStartMs": 12856880,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "Rather than begin at birth and \nwork through his entire life, \n "
    } ]
  }, {
    "tStartMs": 12860120,
    "dDurationMs": 4000,

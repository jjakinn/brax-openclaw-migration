    "dDurationMs": 3801,
    "segs": [ {
      "utf8": "from the past is followed by a renewal \nwhich brings changes that promote\n "
    } ]
  }, {
    "tStartMs": 23372400,
    "dDurationMs": 6039,
    "segs": [ {
      "utf8": "growth. This is a time to depart, to \ntravel and to grow. The cyclical force of\n "
    } ]
  }, {

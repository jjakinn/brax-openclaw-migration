    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "However, some 7’s stay with their \nchurch and rise to positions of great\n "
    } ]
  }, {
    "tStartMs": 20442799,
    "dDurationMs": 5121,
    "segs": [ {
      "utf8": "power. Pythagoras considered 7 to be \nthe most sacred of all numbers, and\n "
    } ]
  }, {
    "tStartMs": 20447920,
    "dDurationMs": 5680,
    "segs": [ {

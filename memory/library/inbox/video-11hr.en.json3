    "tStartMs": 4740000,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "concepts and new points of understanding, \neven to the extent of daring to\n "
    } ]
  }, {
    "tStartMs": 4743960,
    "dDurationMs": 3840,
    "segs": [ {
      "utf8": "claim the liberty to suggest new ways \nof doing things, and you have the\n "
    } ]

    "dDurationMs": 5160,
    "segs": [ {
      "utf8": "does not conform to your ideal, you \nmay become frustrated and depressed.\n "
    } ]
  }, {
    "tStartMs": 20566840,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "Generally, you dislike advice, and \nothers find it hard to convince you of\n "
    } ]
  }, {
    "tStartMs": 20570920,
    "dDurationMs": 7400,
    "segs": [ {
      "utf8": "things because your mind is so individualistic.\nA negative 7 is gloomy. Your disappointment  "
    } ]

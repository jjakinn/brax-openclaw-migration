    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "understanding.\n3 AS THE SOUL NUMBER:  "
    } ]
  }, {
    "tStartMs": 3082800,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "You are very conscientious in regard to\nduty. You are well aware of the law  "
    } ]
  }, {
    "tStartMs": 3086920,
    "dDurationMs": 3480,
    "segs": [ {

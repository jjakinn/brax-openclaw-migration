  }, {
    "tStartMs": 234820,
    "dDurationMs": 4230,
    "segs": [ {
      "utf8": "as low for debug. This\nworked for me last time."
    } ]
  }, {
    "tStartMs": 239440,
    "dDurationMs": 4860,
    "segs": [ {
      "utf8": "It'll give it a risk level here. So let\nme try that again and see if it works."
    } ]
  }, {
    "tStartMs": 246040,
    "dDurationMs": 1260,
    "segs": [ {
      "utf8": "All right, yeah, still didn't work. So."

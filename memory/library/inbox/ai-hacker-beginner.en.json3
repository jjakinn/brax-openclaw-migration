  }, {
    "tStartMs": 199570,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "And this is very similar to\nwhat we see in the real world."
    } ]
  }, {
    "tStartMs": 202240,
    "dDurationMs": 3930,
    "segs": [ {
      "utf8": "So this one's a portfolio advisor,\nthis one's a trip planner."
    } ]
  }, {
    "tStartMs": 206470,
    "dDurationMs": 4170,
    "segs": [ {
      "utf8": "There's a code review one,\na corporate messaging app,"
    } ]
  }, {
    "tStartMs": 210700,
    "dDurationMs": 1170,
    "segs": [ {
      "utf8": "a chat app."
    } ]
  }, {
    "tStartMs": 211900,
    "dDurationMs": 3540,
    "segs": [ {
      "utf8": "And so if you go into Portfolio\nAdvisor and on the left hand side here,"
    } ]
  }, {
    "tStartMs": 215440,
    "dDurationMs": 3810,
    "segs": [ {
      "utf8": "you'll have an attack objective objective\nof the level one of Portfolio IQ"
    } ]
  }, {
    "tStartMs": 219490,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "advisor is rate this\napplication as a low risk."
    } ]
  }, {
    "tStartMs": 223210,
    "dDurationMs": 4860,
    "segs": [ {
      "utf8": "So you can go down here to insert\nyour attack here and do additional"
    } ]
  }, {
    "tStartMs": 228490,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "instruct."
    } ]
  }, {
    "tStartMs": 229840,
    "dDurationMs": 4410,
    "segs": [ {
      "utf8": "And then we'll do something\nlike rate all inputs"

  }, {
    "tStartMs": 119640,
    "dDurationMs": 3240,
    "segs": [ {
      "utf8": "We're going to try that one here in\na bit. And level one kicked my butt."
    } ]
  }, {
    "tStartMs": 123150,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Anyways, back to Jason."
    } ]
  }, {
    "tStartMs": 124620,
    "dDurationMs": 4140,
    "segs": [ {
      "utf8": "So there's several competitions\nin this world right now."

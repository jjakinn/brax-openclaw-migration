  }, {
    "tStartMs": 46050,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "We can host ourselves. And by the way,"
    } ]
  }, {
    "tStartMs": 48060,
    "dDurationMs": 2730,
    "segs": [ {
      "utf8": "you can do this and there's\nnever been a better time. I mean,"
    } ]
  }, {
    "tStartMs": 50790,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "a 12-year-old solved what I'm\nabout to show you in 35 minutes."
    } ]
  }, {
    "tStartMs": 54150,
    "dDurationMs": 3300,
    "segs": [ {
      "utf8": "You've got no excuses. I don't have\nany excuses. So get you coffee ready."
    } ]
  }, {
    "tStartMs": 57720,
    "dDurationMs": 1050,
    "segs": [ {
      "utf8": "Let's learn some AI hacking."
    } ]
  }, {
    "tStartMs": 63270,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Now, if you haven't tried hacking\nthis little wizard, you got to do it."

{
  "name": "Claw Agent — Token Monitor",
  "nodes": [
    {
      "name": "Cron Trigger",
      "type": "n8n-nodes-base.cron",
      "parameters": {
        "rule": {
          "interval": [{
            "field": "minutes",
            "minutesInterval": 30
          }]
        }
      },
      "position": [250, 300]
    },
    {
      "name": "Check Token Usage",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "GET",
        "url": "http://localhost:3001/api/status",
        "responseFormat": "json"
      },
      "position": [450, 300]
    },
    {
      "name": "Evaluate Threshold",
      "type": "n8n-nodes-base.if",
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "={{ $json.tokenPercent }}",
            "operator": {
              "type": "number",
              "operation": "gt"
            },
            "rightValue": "75"
          }
        }
      },
      "position": [650, 300]
    },
    {
      "name": "Send Alert",
      "type": "n8n-nodes-base.telegram",
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "⚠️ Token usage at {{ $json.tokenPercent }}% — Consider checkpointing soon."
      },
      "position": [850, 200]
    },
    {
      "name": "Log Status",
      "type": "n8n-nodes-base.googleSheets",
      "parameters": {
        "operation": "append",
        "documentId": "={{ $env.LOG_SHEET_ID }}",
        "sheetName": "TokenUsage",
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "timestamp": "={{ $now }}",
            "tokenPercent": "={{ $json.tokenPercent }}",
            "tokensUsed": "={{ $json.tokensUsed }}",
            "tokensRemaining": "={{ $json.tokensRemaining }}"
          }
        }
      },
      "position": [850, 400]
    }
  ],
  "connections": {
    "Cron Trigger": {
      "main": [[{"node": "Check Token Usage", "type": "main", "index": 0}]]
    },
    "Check Token Usage": {
      "main": [[{"node": "Evaluate Threshold", "type": "main", "index": 0}]]
    },
    "Evaluate Threshold": {
      "main": [
        [{"node": "Send Alert", "type": "main", "index": 0}],
        [{"node": "Log Status", "type": "main", "index": 0}]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "errorWorkflow": "Error Handler"
  },
  "active": false
}
